---
import Base from '../layouts/Base.astro';

const email = 'contact@carvetrace.com';
const subject = 'CarveTrace — [your organization]';
const mailto = `mailto:${email}?subject=${encodeURIComponent(subject)}`;
---
<Base
  lang="en"
  pageId="contact"
  title="Contact CarveTrace"
  description="Tell us about your use case and we'll show you how the evidence works. Email only, no form, no tracking."
>
  <section class="hero">
    <p class="eyebrow">Get in touch</p>
    <h1>Talk to us</h1>
    <p>
      CarveTrace is built for organizations that need to prove their AI
      decisions when challenged. Tell us about your use case and we'll show
      you how the evidence works.
    </p>
    <div class="hero__ctas">
      <a class="cta cta--primary" href={mailto}>{email}</a>
    </div>
  </section>
</Base>
