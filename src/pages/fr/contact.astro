---
import Base from '../../layouts/Base.astro';

const email = 'contact@carvetrace.com';
const subject = 'CarveTrace — [votre organisation]';
const mailto = `mailto:${email}?subject=${encodeURIComponent(subject)}`;
---
<Base
  lang="fr"
  pageId="contact"
  title="Contacter CarveTrace"
  description="Décrivez-nous votre cas d'usage et nous vous montrerons comment la preuve fonctionne. Email uniquement, pas de formulaire, pas de tracking."
>
  <section class="hero">
    <p class="eyebrow">Nous contacter</p>
    <h1>Parlons-en</h1>
    <p>
      CarveTrace est conçu pour les organisations qui doivent prouver leurs
      décisions IA en cas de contestation. Décrivez-nous votre cas d'usage et
      nous vous montrerons comment la preuve fonctionne.
    </p>
    <div class="hero__ctas">
      <a class="cta cta--primary" href={mailto}>{email}</a>
    </div>
  </section>
</Base>
