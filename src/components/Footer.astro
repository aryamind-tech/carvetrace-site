---
import type { Locale } from '../i18n/routes';
import { t } from '../i18n/ui';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__row">
      <span>{t(lang, 'footer.tagline')}</span>
      <span>
        <a href="https://verify.carvetrace.com" rel="noopener">{t(lang, 'footer.verifier')}</a>
        <span class="site-footer__sep">·</span>
        <a href="https://github.com/aryamind-tech" rel="noopener">{t(lang, 'footer.github')}</a>
      </span>
    </div>
    <div class="site-footer__row site-footer__legal-row">
      <span>
        <a href="/blog/">{t(lang, 'footer.blog')}</a>
        <span class="site-footer__sep">·</span>
        <a href="/deck/">{t(lang, 'footer.deck')}</a>
        <span class="site-footer__sep">·</span>
        <a href="/onboarding/">{t(lang, 'footer.onboarding')}</a>
        <span class="site-footer__sep">·</span>
        <a href="/trust/">{t(lang, 'footer.trust')}</a>
        <span class="site-footer__sep">·</span>
        <a href="/status/">{t(lang, 'footer.status')}</a>
        <span class="site-footer__sep">·</span>
        <a href="/security/">{t(lang, 'footer.security')}</a>
        <span class="site-footer__sep">·</span>
        <a href="/legal/privacy/">{t(lang, 'footer.privacy')}</a>
        <span class="site-footer__sep">·</span>
        <a href="/legal/terms/">{t(lang, 'footer.terms')}</a>
        <span class="site-footer__sep">·</span>
        <a href="/legal/dpa/">{t(lang, 'footer.dpa')}</a>
      </span>
      <small>© {year} {t(lang, 'footer.legal')}</small>
    </div>
  </div>
</footer>
