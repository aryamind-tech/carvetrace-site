---
import { routes, altLocaleHref } from '../i18n/routes';
import type { Locale, PageId } from '../i18n/routes';
import { t } from '../i18n/ui';

interface Props {
  lang: Locale;
  pageId: PageId;
}
const { lang, pageId } = Astro.props;
const home = routes.home[lang];
const langHref = altLocaleHref(pageId, lang);
---
<header class="site-header">
  <div class="site-header__inner">
    <a href={home} class="brand-wordmark" aria-label="CarveTrace">
      <span class="brand-wordmark__carve">Carve</span><span class="brand-wordmark__trace">Trace</span>
    </a>
    <nav class="site-nav" aria-label={lang === 'fr' ? 'Navigation principale' : 'Main navigation'}>
      <a href={routes.why[lang]}>{t(lang, 'nav.why')}</a>
      <a href={routes['how-it-works'][lang]}>{t(lang, 'nav.howItWorks')}</a>
      <a href={routes.demo[lang]}>{t(lang, 'nav.demo')}</a>
      <a href={routes.pricing[lang]}>{t(lang, 'nav.pricing')}</a>
      <a href={routes.docs[lang]}>{t(lang, 'nav.docs')}</a>
      <a href={routes.contact[lang]}>{t(lang, 'nav.contact')}</a>
      <a href={langHref} class="site-nav__lang" hreflang={lang === 'en' ? 'fr' : 'en'}>{t(lang, 'nav.langSwitch')}</a>
    </nav>
  </div>
</header>
